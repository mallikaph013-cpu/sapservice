@model IEnumerable<myapp.Models.Section>

@{
    ViewData["Title"] = "Manage Sections";
}

<div class="row justify-content-center mt-4">
    <div class="col-xl-9 col-lg-10">
        @if (TempData["ImportReport"] != null)
        {
            <div class="alert alert-warning">
                <strong>Import row report</strong>
                <pre class="mb-0 mt-2" style="white-space: pre-wrap;">@TempData["ImportReport"]</pre>
            </div>
        }

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="mb-0"><i class="fas fa-sitemap me-2"></i>@ViewData["Title"]</h1>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus me-2"></i>Create New Section
            </a>
        </div>

        <div class="main-content-card mb-3">
            <h5 class="mb-3"><i class="fas fa-file-import me-2"></i>Import Sections</h5>
            <form asp-action="Import" method="post" enctype="multipart/form-data">
                <div class="row g-2 align-items-end">
                    <div class="col-md-9">
                        <label for="sectionsImportFile" class="form-label">CSV/XLSX File</label>
                        <input type="file" id="sectionsImportFile" name="importFile" class="form-control" accept=".csv,.xlsx" required />
                        <small class="text-light">Columns: SectionName,Department Name</small>
                    </div>
                    <div class="col-md-3">
                        <div class="d-grid gap-2">
                            <a asp-action="DownloadImportTemplate" class="btn btn-outline-secondary"><i class="fas fa-download me-2"></i>Download Template</a>
                            <button type="submit" class="btn btn-success"><i class="fas fa-upload me-2"></i>Import</button>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        @if (Model.Any())
        {
            <div class="main-content-card p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="py-3 ps-4">@Html.DisplayNameFor(model => model.SectionName)</th>
                                <th class="py-3">Department</th>
                                <th class="py-3 text-center" style="width: 160px;">Status</th>
                                <th class="py-3 text-center pe-4" style="width: 160px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4">@Html.DisplayFor(modelItem => item.SectionName)</td>
                                    <td>@(item.Department?.DepartmentName ?? "-")</td>
                                    <td class="text-center">
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td class="text-center pe-4">
                                        <a asp-action="Edit" asp-route-id="@item.SectionId" class="btn btn-icon btn-sm btn-warning me-1" data-bs-toggle="tooltip" title="Edit">
                                            <i class="fas fa-pencil-alt"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.SectionId" class="btn btn-icon btn-sm btn-danger" data-bs-toggle="tooltip" title="Delete">
                                            <i class="fas fa-trash-alt"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="main-content-card text-center">
                <h4 class="text-dark">No sections found.</h4>
                <p class="text-light">Create your first section to get started.</p>
                <a asp-action="Create" class="btn btn-primary mt-2">
                    <i class="fas fa-plus me-2"></i>Create Section
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}

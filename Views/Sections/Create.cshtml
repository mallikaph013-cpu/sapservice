@model myapp.Models.Section

@{
    ViewData["Title"] = "Create Section";
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-7 col-xl-6">
        <div class="main-content-card">
            <div class="text-center mb-4">
                <h2>@ViewData["Title"]</h2>
                <p class="text-light mb-0">Add a new section and assign it to a department.</p>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="form-group mb-3">
                    <label asp-for="SectionName" class="form-label"></label>
                    <input asp-for="SectionName" class="form-control" placeholder="Enter section name" />
                    <small id="section-duplicate-warning" class="text-danger" style="display:none;">Section name already exists in the selected department.</small>
                    <span asp-validation-for="SectionName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="DepartmentId" class="form-label"></label>
                    <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.Departments">
                        <option value="">-- Select Department --</option>
                    </select>
                    <span asp-validation-for="DepartmentId" class="text-danger"></span>
                </div>
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" asp-for="IsActive" />
                    <label class="form-check-label" asp-for="IsActive">Active</label>
                </div>
                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary me-md-2">
                        <i class="fas fa-arrow-left me-2"></i>Back to List
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Create
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.querySelector('form[asp-action="Create"]') || document.querySelector('form');
            const sectionNameInput = document.getElementById('SectionName');
            const departmentSelect = document.getElementById('DepartmentId');
            const duplicateWarning = document.getElementById('section-duplicate-warning');
            const checkUrl = '@Url.Action("CheckDuplicate", "Sections")';

            async function validateDuplicate() {
                if (!sectionNameInput || !departmentSelect) return true;

                const sectionName = (sectionNameInput.value || '').trim();
                const departmentId = departmentSelect.value;

                if (!sectionName || !departmentId) {
                    sectionNameInput.setCustomValidity('');
                    if (duplicateWarning) duplicateWarning.style.display = 'none';
                    return true;
                }

                try {
                    const url = `${checkUrl}?sectionName=${encodeURIComponent(sectionName)}&departmentId=${encodeURIComponent(departmentId)}`;
                    const response = await fetch(url, { method: 'GET' });
                    const data = await response.json();
                    const exists = !!(data && data.exists);

                    if (exists) {
                        sectionNameInput.setCustomValidity('Section name already exists in the selected department.');
                        if (duplicateWarning) duplicateWarning.style.display = 'inline';
                        return false;
                    }

                    sectionNameInput.setCustomValidity('');
                    if (duplicateWarning) duplicateWarning.style.display = 'none';
                    return true;
                } catch {
                    // Do not block users on network/intermittent errors; server-side validation still protects data.
                    sectionNameInput.setCustomValidity('');
                    if (duplicateWarning) duplicateWarning.style.display = 'none';
                    return true;
                }
            }

            if (sectionNameInput) {
                sectionNameInput.addEventListener('blur', validateDuplicate);
                sectionNameInput.addEventListener('input', () => {
                    sectionNameInput.setCustomValidity('');
                    if (duplicateWarning) duplicateWarning.style.display = 'none';
                });
            }

            if (departmentSelect) {
                departmentSelect.addEventListener('change', validateDuplicate);
            }

            if (form) {
                form.addEventListener('submit', async function (event) {
                    const isUnique = await validateDuplicate();
                    if (!isUnique || !form.checkValidity()) {
                        event.preventDefault();
                        if (typeof form.reportValidity === 'function') {
                            form.reportValidity();
                        }
                    }
                });
            }
        });
    </script>
}

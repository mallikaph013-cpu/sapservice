@model IEnumerable<myapp.Models.AuditLog>

@{
    ViewData["Title"] = "Audit Logs";
}

<div class="row justify-content-center mt-4">
    <div class="col-xl-11">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h1 class="mb-0"><i class="fas fa-clipboard-list me-2"></i>@ViewData["Title"]</h1>
        </div>

        <div class="main-content-card mb-3">
            <form method="get" asp-action="Index">
                <div class="row g-3 align-items-end">
                    <div class="col-md-2">
                        <label for="action" class="form-label">Action</label>
                        <select id="action" name="action" class="form-select">
                            <option value="">All</option>
                            @foreach (var actionOption in (IEnumerable<string>)(ViewBag.ActionOptions ?? Enumerable.Empty<string>()))
                            {
                                var isSelected = string.Equals((string?)ViewBag.Action, actionOption, StringComparison.OrdinalIgnoreCase);
                                <option value="@actionOption" selected="@isSelected">@actionOption</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="entity" class="form-label">Entity</label>
                        <input id="entity" name="entity" class="form-control" value="@ViewBag.Entity" placeholder="e.g. RequestItem" />
                    </div>
                    <div class="col-md-2">
                        <label for="performedBy" class="form-label">Performed By</label>
                        <input id="performedBy" name="performedBy" class="form-control" value="@ViewBag.PerformedBy" placeholder="username" />
                    </div>
                    <div class="col-md-2">
                        <label for="fromDate" class="form-label">From Date</label>
                        <input id="fromDate" name="fromDate" type="date" class="form-control" value="@ViewBag.FromDate" />
                    </div>
                    <div class="col-md-2">
                        <label for="toDate" class="form-label">To Date</label>
                        <input id="toDate" name="toDate" type="date" class="form-control" value="@ViewBag.ToDate" />
                    </div>
                    <div class="col-md-2">
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary"><i class="fas fa-filter me-1"></i>Filter</button>
                            <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-rotate-left me-1"></i>Reset</a>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        @if (Model.Any())
        {
            <div class="main-content-card p-0 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="py-3 ps-4">Date/Time (UTC)</th>
                                <th class="py-3">Entity</th>
                                <th class="py-3">Entity Id</th>
                                <th class="py-3">Action</th>
                                <th class="py-3">Performed By</th>
                                <th class="py-3 pe-4">Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in Model)
                            {
                                <tr>
                                    <td class="ps-4">@log.PerformedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td>@log.EntityName</td>
                                    <td>@log.EntityId</td>
                                    <td>@log.Action</td>
                                    <td>@log.PerformedBy</td>
                                    <td class="pe-4">@log.Details</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="main-content-card text-center">
                <h4 class="text-dark">No audit logs found.</h4>
            </div>
        }
    </div>
</div>

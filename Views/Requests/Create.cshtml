@model myapp.Models.ViewModels.CreateRequestViewModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = "Create Service Request";
}

<style>
    #create-form .form-control[readonly] {
        background-color: var(--bs-secondary-bg);
    }

    .create-import-card {
        order: 1;
        margin-bottom: 3rem;
    }

    .create-manual-card {
        order: 2;
    }
</style>

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9 d-flex flex-column">

        <!-- Manual Creation Form -->
        <div class="main-content-card mb-5 create-manual-card">
            <div class="text-center mb-4">
                <h2>Create New Service Request</h2>
               @*<p class="text-light">Please fill in the details of your request below.</p>*@ 
            </div>

            <form id="create-form" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                <h5>Requester Information</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-4"><div class="form-group"><label asp-for="RequesterName" class="form-label"></label><input asp-for="RequesterName" class="form-control" readonly /></div></div>
                    <div class="col-md-3"><div class="form-group"><label asp-for="Department" class="form-label"></label><input asp-for="Department" class="form-control" readonly /></div></div>
                    <div class="col-md-2"><div class="form-group"><label asp-for="Section" class="form-label"></label><input asp-for="Section" class="form-control" readonly /></div></div>
                    <div class="col-md-3"><div class="form-group"><label asp-for="RequesterPlant" class="form-label"></label><input asp-for="RequesterPlant" class="form-control" readonly /></div></div>
                </div>

                <hr class="my-4">

                <h5>Request Details</h5>
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="RequestType" class="form-label">Request Type</label>
                            <select asp-for="RequestType" id="RequestType" class="form-select" asp-items="Html.GetEnumSelectList<myapp.Models.RequestType>()">
                                <option value="">-- Select Type --</option>
                            </select>
                            <span asp-validation-for="RequestType" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Plant" class="form-label"></label>
                            <select asp-for="Plant" id="RequestPlant" class="form-select">
                                <option value="">-- Select Plant --</option>
                                <option value="6021">6021 (Device)</option>
                                <option value="6031">6031 (Assembly)</option>
                                <option value="6051">6051 (Injection)</option>
                                <option value="6081">6081 (IPO)</option>
                                <option value="6090">6090</option>
                            </select>
                            <span asp-validation-for="Plant" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="form-group mb-4">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Provide a detailed description of the request..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <partial name="_MaterialForms" model="Model" />

                <hr class="my-4">

                <h5>Work Flow</h5>
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label for="NextResponsibleUserId" class="form-label">ผู้รับผิดชอบลำดับถัดไป</label>
                            <select name="NextResponsibleUserId" id="NextResponsibleUserId" class="form-select">
                                <option value="">-- Please select a request type first --</option>
                            </select>
                        </div>
                    </div>
                </div>
                @* ੾�����˹�ҷ�� IT *@
                @if (SignInManager.IsSignedIn(User) && User.IsInRole("IT"))
                {
                    <hr class="my-4" />
                    <h5>DX Update Status</h5>
                     <div class="row mb-4">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Status" class="form-label"></label>
                                <select asp-for="Status" id="CreateStatus" class="form-select">
                                    <option value="Pending">Pending</option>
                                    <option value="Run Standard Cost">Run Standard Cost</option>
                                    <option value="Check and Confirm">Check and Confirm</option>
                                    <option value="Release">Release</option>
                                    <option value="Input Price">Input Price</option>
                                    <option value="Complete">Complete</option>
                                    <option value="Rejected">Rejected</option>
                                </select>
                            </div>
                        </div>
                    </div>
                }

                <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                    <a asp-action="Index" class="btn btn-outline-secondary me-md-2">
                        <i class="fas fa-arrow-left me-1"></i> Back to List
                    </a>
                    <button type="submit" id="create-submit-button" class="btn btn-primary">
                        <i class="fas fa-paper-plane me-2"></i>Submit Request
                    </button>
                </div>
            </form>
        </div>

        <!-- Excel Import Form -->
        <div class="main-content-card create-import-card">
             <div class="text-center mb-4">
                <h2>Import from Excel</h2>
                @*<p class="text-light">Quickly add multiple requests by uploading a pre-filled Excel file.</p>*@
            </div>
            <form id="import-form" asp-action="Import" method="post" enctype="multipart/form-data">
                <div class="mb-3">
                    <label for="ImportRequestType" class="form-label">Request Type (Template)</label>
                    <select id="ImportRequestType" class="form-select" asp-items="Html.GetEnumSelectList<myapp.Models.RequestType>()">
                        <option value="">-- Select Type --</option>
                    </select>
                </div>
                 <div class="mb-3">
                    <label for="excelFile" class="form-label">Select Excel File (.xlsx, .xls)</label>
                    <input class="form-control" type="file" id="excelFile" name="file" accept=".xlsx, .xls" required>
                </div>

                <input type="hidden" name="NextResponsibleUserId" id="importNextResponsibleUserId" />
                
                <div class="d-flex justify-content-center align-items-center mt-4">
                    <div class="input-group">
                        <a id="download-template-link" href="#" class="btn btn-outline-secondary disabled">
                            <i class="fas fa-download me-2"></i>Download Template
                        </a>
                        <button type="submit" id="import-submit-button" class="btn btn-success">
                            <i class="fas fa-file-excel me-2"></i>Import File
                        </button>
                    </div>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const requestTypeSelect = document.getElementById('RequestType');
            const requestPlantSelect = document.getElementById('RequestPlant');
            const requesterNameInput = document.getElementById('RequesterName');
            const materialFieldsContainer = document.getElementById('material-fields-container');
            const allMaterialFields = materialFieldsContainer ? materialFieldsContainer.querySelectorAll('[data-types]') : [];
            const bomContainer = document.getElementById('bom-fields-container');
            const bomEditContainer = document.getElementById('bom-edit-fields-container');
            const routingContainer = document.getElementById('routing-fields-container');
            const licensePermissionContainer = document.getElementById('license-permission-fields-container');
            const nextResponsibleUserSelect = document.getElementById('NextResponsibleUserId');
            const importNextResponsibleUserIdInput = document.getElementById('importNextResponsibleUserId');
            const createForm = document.getElementById('create-form');
            const importForm = document.getElementById('import-form');
            const downloadLink = document.getElementById('download-template-link');
            const importRequestTypeSelect = document.getElementById('ImportRequestType');
            const distributionChannelSelect = document.getElementById('DistributionChannel');
            const boiCodeContainer = document.getElementById('boi-code-container');
            const editBomFgInput = document.getElementById('EditBomFg');
            const editBomAllFgCheckbox = document.getElementById('EditBomAllFg');
            let lastSuccessfulApprovers = [];

            const typeMapping = {
                '0': 'FG',
                '1': 'SM',
                '2': 'RM',
                '3': 'ToolingB',
                '4': 'ToolingBFG',
                '5': 'ToolingBPU',
                '6': 'BOM',
                '7': 'Routing',
                '8': 'AddStorage',
                '9': 'DistributionChanel',
                '10': 'IPO',
                '11': 'Passthrough',
                '12': 'CrossPlantPurchase',
                '13': 'EditBOM',
                '14': 'LicensePermission'

                

            };

            function toggleBoiCode() {
                if (!distributionChannelSelect) return;
                const selectedChannel = distributionChannelSelect.value;
                // Show BOI Code field only if Distribution Channel is 'Indirect' (2) or 'Export' (3)
                if (selectedChannel === '2' || selectedChannel === '3') {
                    boiCodeContainer.style.display = 'block';
                } else {
                    boiCodeContainer.style.display = 'none';
                }
            }

            function toggleEditBomFgInput() {
                if (!editBomFgInput || !editBomAllFgCheckbox) return;
                const isAllFgChecked = editBomAllFgCheckbox.checked;
                editBomFgInput.disabled = isAllFgChecked;
                if (isAllFgChecked) {
                    editBomFgInput.value = '';
                }
            }

            function toggleMaterialFields() {
                if (!requestTypeSelect) return;
                const selectedValue = requestTypeSelect.value;
                // support enum value as numeric string or as name (e.g. "6" or "BOM")
                let selectedTypeName = '';
                if (selectedValue) {
                    selectedTypeName = typeMapping[selectedValue] || selectedValue;
                }
                //Treat EditBOM like BOM for field visibility
                if (selectedTypeName === 'EditBOM' || selectedTypeName === 'แก้ BOM') {
                    selectedTypeName = 'EditBOM';
                }

                const showMaterialFields = selectedValue && selectedTypeName !== 'Routing' && selectedTypeName !== 'LicensePermission';
                if (materialFieldsContainer) materialFieldsContainer.style.display = showMaterialFields ? 'block' : 'none';

                if (showMaterialFields && allMaterialFields.length) {
                    allMaterialFields.forEach(field => {
                        const parentCol = field.closest('.col-md-4, .col-md-6, .col-md-8, .col-md-12');
                        if (parentCol) {
                            const types = parentCol.dataset.types ? parentCol.dataset.types.split(',') : [];
                            if (selectedTypeName && types.includes(selectedTypeName)) {
                                parentCol.style.display = 'block';
                            } else {
                                parentCol.style.display = 'none';
                            }
                        }
                    });
                }

                    const isBom = selectedTypeName === 'BOM';
                    const isEditBom = selectedTypeName === 'EditBOM';
                    const isLicensePermission = selectedTypeName === 'LicensePermission';

                //��� block �����ʴ� UI �ͧ BOM EditBom Routing

                if (bomEditContainer) bomEditContainer.style.display = (isEditBom) ? 'block' : 'none';
                if (routingContainer) routingContainer.style.display = selectedTypeName === 'Routing' ? 'block' : 'none';
                if (bomContainer) bomContainer.style.display = (isBom) ? 'block' : 'none';
                if (licensePermissionContainer) licensePermissionContainer.style.display = isLicensePermission ? 'block' : 'none';

                // After toggling all fields, specifically check for BOI code visibility
                toggleBoiCode();
            }

            const getNextApproversUrl = '@Url.Action("GetNextApprovers", "Requests")';
            const downloadTemplateUrl = '@Url.Action("DownloadTemplate", "Requests")';

            @* Check next Approve *@
            function fetchNextApprovers() {
                const requestTypeValue = requestTypeSelect.value;
                const selectedPlant = requestPlantSelect ? requestPlantSelect.value : '';
                const requesterNameValue = requesterNameInput ? requesterNameInput.value : '';
                nextResponsibleUserSelect.innerHTML = '<option value="">-- Loading...--</option>';

                const renderApproverOptions = (data) => {
                    nextResponsibleUserSelect.innerHTML = '<option value="">-- Please select a responsible user --</option>';
                    data.forEach(user => {
                        const stepPrefix = user.step ? `Step ${user.step} - ` : '';
                        const option = new Option(`${stepPrefix}${user.fullName}`, user.id);
                        nextResponsibleUserSelect.add(option);
                    });

                    if (data.length === 1) {
                        nextResponsibleUserSelect.value = data[0].id;
                    }

                    importNextResponsibleUserIdInput.value = nextResponsibleUserSelect.value || '';
                    lastSuccessfulApprovers = data;
                };

                if (requestTypeValue) {
                    fetch(`${getNextApproversUrl}?requestType=${encodeURIComponent(requestTypeValue)}&plant=${encodeURIComponent(selectedPlant)}&requesterName=${encodeURIComponent(requesterNameValue)}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data && data.length > 0) {
                                renderApproverOptions(data);
                            } else {
                                // Fallback: retry without plant filter in case route config uses different plant labels.
                                fetch(`${getNextApproversUrl}?requestType=${encodeURIComponent(requestTypeValue)}&requesterName=${encodeURIComponent(requesterNameValue)}`)
                                    .then(r => r.json())
                                    .then(fallbackData => {
                                        if (fallbackData && fallbackData.length > 0) {
                                            renderApproverOptions(fallbackData);
                                        } else if (lastSuccessfulApprovers.length > 0) {
                                            renderApproverOptions(lastSuccessfulApprovers);
                                        } else {
                                            nextResponsibleUserSelect.innerHTML = '<option value="">-- No users found --</option>';
                                            importNextResponsibleUserIdInput.value = '';
                                        }
                                    })
                                    .catch(() => {
                                        if (lastSuccessfulApprovers.length > 0) {
                                            renderApproverOptions(lastSuccessfulApprovers);
                                        } else {
                                            nextResponsibleUserSelect.innerHTML = '<option value="">-- Error loading data --</option>';
                                            importNextResponsibleUserIdInput.value = '';
                                        }
                                    });
                            }
                        })
                        .catch(error => {
                            console.error('Error fetching approvers:', error);
                            if (lastSuccessfulApprovers.length > 0) {
                                renderApproverOptions(lastSuccessfulApprovers);
                            } else {
                                nextResponsibleUserSelect.innerHTML = '<option value="">-- Error loading data --</option>';
                                importNextResponsibleUserIdInput.value = '';
                            }
                        });
                } else {
                    nextResponsibleUserSelect.innerHTML = '<option value="">-- Please select a request type first --</option>';
                    importNextResponsibleUserIdInput.value = '';
                }
            }
            
            function updateDownloadLink() {
                const selectedValue = importRequestTypeSelect ? importRequestTypeSelect.value : '';
                if (selectedValue) {
                    downloadLink.href = `${downloadTemplateUrl}?requestType=${encodeURIComponent(selectedValue)}`;
                    downloadLink.classList.remove('disabled');
                } else {
                    downloadLink.href = '#';
                    downloadLink.classList.add('disabled');
                }
            }

            function checkResponsibleUser(event) {
                const hasApproverOptions = Array.from(nextResponsibleUserSelect.options || [])
                    .some(option => option.value && option.value.trim() !== '');

                if (hasApproverOptions && nextResponsibleUserSelect.value === '') {
                    event.preventDefault(); // Stop form submission
                    Swal.fire({
                        title: 'Incomplete Information',
                        text: "Please select a 'Next Responsible User' before submitting.",
                        icon: 'warning',
                        confirmButtonColor: '#F97316' // Primary Orange
                    });
                }
            }

            // --- BOM & Routing Logic from Edit.cshtml ---
            function addBomItem(level) {
                const tbody = document.getElementById('bom-items-body');
                if (!tbody) return;
                const index = tbody.getElementsByTagName('tr').length;
                const parentReadonly = level === 1 ? 'readonly' : '';
                const componentBomUsageReadonly = level === 2 ? 'readonly' : '';
                const newRow = `
                    <tr>
                        <td><input type="text" name="Components[${index}].Level" class="form-control" value="${level}" readonly/></td>
                        <td><input type="text" name="Components[${index}].Item" class="form-control" ${parentReadonly} /></td>
                        <td><input type="text" name="Components[${index}].ItemCat" class="form-control" ${parentReadonly} /></td>
                        <td><input type="text" name="Components[${index}].ComponentNumber" class="form-control" /></td>
                        <td><input type="text" name="Components[${index}].Description" class="form-control" /></td>
                        <td><input type="number" name="Components[${index}].ItemQuantity" class="form-control" ${parentReadonly} /></td>
                        <td><input type="text" name="Components[${index}].Unit" class="form-control" ${parentReadonly} /></td>
                        <td><input type="text" name="Components[${index}].BomUsage" class="form-control" ${componentBomUsageReadonly} /></td>
                        <td><input type="text" name="Components[${index}].Plant" class="form-control" /></td>
                        <td><input type="text" name="Components[${index}].Sloc" class="form-control" ${parentReadonly} /></td>
                        <td><button type="button" class="btn btn-danger btn-sm remove-bom-item">Remove</button></td>
                    </tr>`;
                tbody.insertAdjacentHTML('beforeend', newRow);
            }

            const addParentBtn = document.getElementById('add-parent-item');
            const addChildBtn = document.getElementById('add-child-item');
            if (addParentBtn) addParentBtn.addEventListener('click', () => addBomItem(1));
            if (addChildBtn) addChildBtn.addEventListener('click', () => addBomItem(2));

            const bomBody = document.getElementById('bom-items-body');
            if (bomBody) {
                bomBody.addEventListener('click', function(e) {
                    if (e.target && e.target.classList.contains('remove-bom-item')) {
                        e.target.closest('tr').remove();
                    }
                });
            }


            @*------------------------------Edit BOM--------------------------------------*@

             function addBomEditItem(level) {
                const tbody = document.getElementById('bom-edit-items-body');
                if (!tbody) return;
                const index = tbody.getElementsByTagName('tr').length;
                const newRow = `
                    <tr>
                        <td><input type="text" name="EditBOM[${index}].ItemCodeFrom" class="form-control" /></td>
                        <td><input type="text" name="EditBOM[${index}].DescriptionFrom" class="form-control" /></td>
                        <td><input type="text" name="EditBOM[${index}].ItemQuantityFrom" class="form-control" /></td>
                        <td><input type="text" name="EditBOM[${index}].UnitFrom" class="form-control" /></td>
                        <td><input type="text" name="EditBOM[${index}].BomUsageFrom" class="form-control" /></td>
                        <td><input type="text" name="EditBOM[${index}].SlocFrom" class="form-control" /></td>
                        <td></td>


                        <td><input type="text" name="EditBOM[${index}].ItemCodeTo" class="form-control" /></td>
                        <td><input type="text" name="EditBOM[${index}].DescriptionTo" class="form-control" /></td>
                        <td><input type="text" name="EditBOM[${index}].ItemQuantityTo" class="form-control" /></td>
                        <td><input type="text" name="EditBOM[${index}].UnitTo" class="form-control" /></td>
                        <td><input type="text" name="EditBOM[${index}].BomUsageTo" class="form-control" /></td>
                        <td><input type="text" name="EditBOM[${index}].SlocTo" class="form-control" /></td>
                        <td><button type="button" class="btn btn-danger btn-sm remove-editbom-item">Remove</button></td>
                    </tr>`;
                tbody.insertAdjacentHTML('beforeend', newRow);
            }


                    const addEditBomBtn = document.getElementById('add-editbom-row');
                    if (addEditBomBtn) {
                       addEditBomBtn.addEventListener('click', () => addBomEditItem());
                    }

                    const editBomBody = document.getElementById('bom-edit-items-body');
                    if (editBomBody) {
                        editBomBody.addEventListener('click', function (e) {
                            if (e.target && e.target.classList.contains('remove-editbom-item')) {
                                e.target.closest('tr').remove();
                            }
                        });
                    }


            @*---------------------------------Routing------------------------------------*@ 

            const addRoutingBtn = document.getElementById('add-routing-item');
            if (addRoutingBtn) addRoutingBtn.addEventListener('click', function() {
                const tbody = document.getElementById('routing-items-body');
                if (!tbody) return;
                const index = tbody.rows.length;
                const row = `
                    <tr>
                        <td><input class="form-control" type="text" name="Routings[${index}].Counter"></td>
                        <td><input class="form-control" type="text" name="Routings[${index}].Plant"></td>
                        <td><input class="form-control" type="text" name="Routings[${index}].Material"></td>
                        <td><input class="form-control" type="text" name="Routings[${index}].Description"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].WorkCenter"></td>
                        <td class="routing-spacer-col"></td>
                        <td class="routing-spacer-col"></td>
                        <td class="routing-spacer-col"></td>
                        <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td><input class="form-control" type="number" step="0.01" name="Routings[${index}].BaseQty" value="1"></td>
                    <td><input class="form-control routing-unit-source" type="text" name="Routings[${index}].Unit"></td>
                    <td><input class="form-control" type="number" step="0.01" name="Routings[${index}].DirectLaborCosts"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td><input class="form-control" type="number" step="0.01" name="Routings[${index}].DirectExpenses"></td>
                        <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td><input class="form-control" type="number" step="0.01" name="Routings[${index}].AllocationExpense"></td>
                        <td class="routing-spacer-col"></td>
                        <td><input class="form-control" type="text" name="Routings[${index}].ProductionVersionCode"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].Version"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                        <td><input class="form-control" type="date" name="Routings[${index}].ValidFrom"></td>
                        <td><input class="form-control" type="date" name="Routings[${index}].ValidTo" value="9999-12-13"></td>
                        <td class="routing-spacer-col"></td>
                        <td><input class="form-control" type="number" step="0.01" name="Routings[${index}].MaximumLotSize" value="99999999"></td>
                        <td><input class="form-control routing-unit-mirror" type="text" readonly></td>
                        <td><input class="form-control" type="text" name="Routings[${index}].Alternative" value="1" readonly></td>
                        <td><input class="form-control" type="text" name="Routings[${index}].BomUsage" value="1"></td>
                        <td class="routing-spacer-col"></td>
                        <td><input class="form-control" type="text" name="Routings[${index}].Group"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].GroupCounter" value="1"></td>
                        <td><button type="button" class="btn btn-danger btn-sm remove-routing-item">Remove</button></td>
                    </tr>`;
                tbody.insertAdjacentHTML('beforeend', row);
            });

            const routingBody = document.getElementById('routing-items-body');
            if (routingBody) {
                const syncRoutingUnitMirror = (row) => {
                    const source = row.querySelector('.routing-unit-source');
                    const mirror = row.querySelector('.routing-unit-mirror');
                    if (source && mirror) {
                        mirror.value = source.value || '';
                    }
                };

                routingBody.querySelectorAll('tr').forEach(syncRoutingUnitMirror);

                routingBody.addEventListener('input', function (e) {
                    if (e.target && e.target.classList.contains('routing-unit-source')) {
                        const row = e.target.closest('tr');
                        if (row) {
                            syncRoutingUnitMirror(row);
                        }
                    }
                });

                routingBody.addEventListener('click', function(e) {
                    if (e.target && e.target.classList.contains('remove-routing-item')) {
                        e.target.closest('tr').remove();
                    }
                });
            }

            const addLicensePermissionBtn = document.getElementById('add-license-permission-item');
            const licenseRequestOptionSelect = document.getElementById('LicenseRequestOption');
            const licenseNewUsernameFields = document.getElementById('license-new-username-fields');
            const licenseAddPermissionFields = document.getElementById('license-add-permission-fields');
            const licensePrimaryUsernameInput = document.getElementById('LicensePrimaryUsername');
            const licenseSecondaryUsernameInput = document.getElementById('LicenseSecondaryUsername');

            function setSectionEnabled(section, enabled) {
                if (!section) return;
                const controls = section.querySelectorAll('input, select, textarea, button');
                controls.forEach(control => {
                    control.disabled = !enabled;
                });
            }

            function toggleLicenseRequestOptionFields() {
                const selectedOption = licenseRequestOptionSelect ? licenseRequestOptionSelect.value : '';
                const isNewUsernameRequest = selectedOption === 'NewUsername';
                const isAddPermissionRequest = selectedOption === 'AddPermission';

                if (licenseNewUsernameFields) {
                    licenseNewUsernameFields.style.display = isNewUsernameRequest ? 'block' : 'none';
                    setSectionEnabled(licenseNewUsernameFields, isNewUsernameRequest);
                }

                if (licenseAddPermissionFields) {
                    licenseAddPermissionFields.style.display = isAddPermissionRequest ? 'block' : 'none';
                    setSectionEnabled(licenseAddPermissionFields, isAddPermissionRequest);
                }
            }

            function getLicenseUsernames() {
                const usernames = [];
                const primary = licensePrimaryUsernameInput ? licensePrimaryUsernameInput.value.trim() : '';
                const secondary = licenseSecondaryUsernameInput ? licenseSecondaryUsernameInput.value.trim() : '';
                if (primary) usernames.push(primary);
                if (secondary) usernames.push(secondary);
                return usernames;
            }

            function getCombinedLicenseUsernames() {
                return getLicenseUsernames().join(' / ');
            }

            function syncLicensePermissionUsernames() {
                const combinedUsernames = getCombinedLicenseUsernames();
                const usernameInputs = document.querySelectorAll('#license-permission-items-body .license-permission-username');
                usernameInputs.forEach(input => {
                    input.value = combinedUsernames;
                });
            }

            function hydrateLicenseUsernameInputsFromRows() {
                if (!licensePrimaryUsernameInput || !licenseSecondaryUsernameInput) return;
                const usernameInputs = document.querySelectorAll('#license-permission-items-body .license-permission-username');
                const rawValues = Array.from(usernameInputs)
                    .map(input => (input.value || '').trim())
                    .filter(value => value.length > 0);

                if (!rawValues.length) return;

                const parsedUsers = [];
                rawValues.forEach(value => {
                    value.split(/\s*\/\s*|\s*,\s*/)
                        .map(part => part.trim())
                        .filter(part => part.length > 0)
                        .forEach(user => {
                            if (!parsedUsers.includes(user)) {
                                parsedUsers.push(user);
                            }
                        });
                });

                if (parsedUsers[0]) licensePrimaryUsernameInput.value = parsedUsers[0];
                if (parsedUsers[1]) licenseSecondaryUsernameInput.value = parsedUsers[1];
                syncLicensePermissionUsernames();
            }

            if (addLicensePermissionBtn) {
                addLicensePermissionBtn.addEventListener('click', function() {
                    const tbody = document.getElementById('license-permission-items-body');
                    if (!tbody) return;
                    const index = tbody.getElementsByTagName('tr').length;
                    const combinedUsernames = getCombinedLicenseUsernames();
                    const row = `
                        <tr>
                            <td>
                                <input class="license-permission-username" type="hidden" name="LicensePermissions[${index}].SapUsername" value="${combinedUsernames}">
                                <input class="form-control" type="text" name="LicensePermissions[${index}].TCode">
                            </td>
                            <td><button type="button" class="btn btn-danger btn-sm remove-license-permission-item">Remove</button></td>
                        </tr>`;
                    tbody.insertAdjacentHTML('beforeend', row);
                });
            }

            const licensePermissionBody = document.getElementById('license-permission-items-body');
            if (licensePermissionBody) {
                licensePermissionBody.addEventListener('click', function(e) {
                    if (e.target && e.target.classList.contains('remove-license-permission-item')) {
                        e.target.closest('tr').remove();
                    }
                });
            }

            // Initial setup
            toggleMaterialFields();
            updateDownloadLink();
            fetchNextApprovers(); // Fetch approvers on page load if a type is already selected
            hydrateLicenseUsernameInputsFromRows();
            toggleLicenseRequestOptionFields();

            // Event Listeners
            requestTypeSelect.addEventListener('change', () => {
                toggleMaterialFields();
                fetchNextApprovers();
            });

            if (requestPlantSelect) {
                requestPlantSelect.addEventListener('change', fetchNextApprovers);
            }

            if (importRequestTypeSelect) {
                importRequestTypeSelect.addEventListener('change', updateDownloadLink);
            }

            if (distributionChannelSelect) {
                 distributionChannelSelect.addEventListener('change', toggleBoiCode);
            }
              if (editBomAllFgCheckbox) {
                 editBomAllFgCheckbox.addEventListener('change', toggleEditBomFgInput);
              }

              toggleEditBomFgInput();

            nextResponsibleUserSelect.addEventListener('change', () => {
                 importNextResponsibleUserIdInput.value = nextResponsibleUserSelect.value;
            });
            if (licensePrimaryUsernameInput) {
                licensePrimaryUsernameInput.addEventListener('input', syncLicensePermissionUsernames);
            }
            if (licenseSecondaryUsernameInput) {
                licenseSecondaryUsernameInput.addEventListener('input', syncLicensePermissionUsernames);
            }
            if (licenseRequestOptionSelect) {
                licenseRequestOptionSelect.addEventListener('change', toggleLicenseRequestOptionFields);
            }

            createForm.addEventListener('submit', syncLicensePermissionUsernames);
            importForm.addEventListener('submit', checkResponsibleUser);
        });
    </script>
}

@model myapp.Models.RequestItem

@{
    ViewData["Title"] = "Request Details";

    // Helper to get status badge color class
    Func<string, string> GetStatusClass = (status) => {
        switch (status?.ToLower()) {
            case "approved": return "status-approved";
            case "rejected": return "status-rejected";
            case "processing": return "status-processing";
            case "complete": return "status-approved"; // Assuming complete is a success status
            default: return "status-pending";
        }
    };

    // Helper to render a data field only if the value is not null, empty, or whitespace
    Action<string, string?> RenderDetailField = (label, value) => {
        if (!string.IsNullOrWhiteSpace(value)) {
            <div class="col-md-4 mb-2">
                <strong>@label:</strong>
                <span class="text-secondary">@value</span>
            </div>
        }
    };
}

<div class="row justify-content-center">
    <div class="col-lg-10 col-xl-9">
        <div class="main-content-card">

            <!-- Header -->
            <div class="d-flex justify-content-between align-items-start mb-4">
                <div>
                    <h2 class="mb-1">Details for Request #@Model.Id</h2>
                    <p class="text-dark fw-semibold mb-0">Type: @Model.RequestType</p>
                    <p class="text-dark fw-semibold mb-0">Document No.: @(string.IsNullOrWhiteSpace(Model.DocumentNumber) ? "-" : Model.DocumentNumber)</p>
                </div>
                <span class="request-status @GetStatusClass(Model.Status)">@Model.Status</span>
            </div>

            <!-- Requester Info -->
            <div class="mb-4">
                <h5 class="mb-3">Requester Information</h5>
                <div class="row g-3">
                    <div class="col-md-6"><strong>Requester:</strong> <span class="text-secondary">@Model.Requester</span></div>
                    <div class="col-md-6"><strong>Request Date:</strong> <span class="text-secondary">@Model.RequestDate.ToString("MMMM dd, yyyy")</span></div>
                    <div class="col-md-6"><strong>ผู้รับผิดชอบลำดับถัดไป:</strong> <span class="text-secondary">@ViewBag.NextResponsibleUserName</span></div>
                </div>
            </div>

            <hr class="my-4">

            <!-- Request Details -->
            <div class="mb-4">
                <h5 class="mb-3">Request Details</h5>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p class="description-box">@Html.Raw(Model.Description.Replace("\n", "<br />"))</p>
                }

                @if ((Model.RequestType == "Request" || Model.RequestType == "ร้องขอ") && !string.IsNullOrWhiteSpace(Model.AttachmentPath))
                {
                    <div class="mt-3">
                        <strong>Attachment:</strong>
                        <a href="@Model.AttachmentPath" target="_blank" rel="noopener">
                            @(string.IsNullOrWhiteSpace(Model.AttachmentFileName) ? "Open attachment" : Model.AttachmentFileName)
                        </a>
                    </div>
                }
            </div>

            <!-- Material Info -->
            @if (Model.RequestType != "BOM" && Model.RequestType != "Routing")
            {
                <hr class="my-4">
                <div class="mb-4">
                    <h5 class="mb-3">Material Information</h5>
                    <div class="row g-3">
                        @{
                            var requestType = Model.RequestType;
                            
                            RenderDetailField("Item Code", Model.ItemCode);
                            RenderDetailField("English Mat/Description", Model.EnglishMatDescription);

                            if (requestType == "FG" || requestType == "RM" || requestType == "ToolingB" || requestType == "IPO") { RenderDetailField("Model Name", Model.ModelName); }
                            if (requestType != "AddStorage") { RenderDetailField("Base Unit", Model.BaseUnit); }
                            if (requestType != "AddStorage") { RenderDetailField("Material Group", Model.MaterialGroup); }
                            if (requestType != "AddStorage") { RenderDetailField("External Material Group", Model.ExternalMaterialGroup); }
                            if (requestType == "FG" || requestType == "SM" || requestType == "RM" || requestType == "ToolingB" || requestType == "DistributionChanel" || requestType == "IPO") { RenderDetailField("Division", Model.DivisionCode); }
                            if (requestType != "AddStorage") { RenderDetailField("Profit Center", Model.ProfitCenter); }
                            if (requestType == "FG" || requestType == "SM" || requestType == "RM" || requestType == "IPO") { RenderDetailField("MRP Controller", Model.MrpController); }
                            if (requestType == "FG" || requestType == "SM" || requestType == "RM" || requestType == "AddStorage" || requestType == "IPO") { RenderDetailField("Storage Location", Model.StorageLocation); }
                            if (requestType == "FG" || requestType == "RM" || requestType == "IPO") { RenderDetailField("Valuation Class", Model.ValClass); }
                            if (requestType == "RM" || requestType == "ToolingB" || requestType == "IPO") { RenderDetailField("Price", Model.Price?.ToString("C")); }
                            if (requestType == "RM" || requestType == "ToolingB" || requestType == "IPO") { RenderDetailField("Purchasing Group", Model.PurchasingGroup); }
                            if (requestType == "FG" || requestType == "DistributionChanel" || requestType == "IPO") { RenderDetailField("Distribution Channel", Model.DistributionChannel); }
                            if (requestType == "IPO") { RenderDetailField("Tariff Code", Model.TariffCode); }
                            if (requestType == "IPO") { RenderDetailField("Planner", Model.Planner); }
                        }
                    </div>
                </div>
            }

            <!-- BOM Components Table -->
            @if (Model.BomComponents != null && Model.BomComponents.Any())
            {
                <hr class="my-4">
                <div class="mb-4">
                    <h5 class="mb-3">BOM Components</h5>
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>Level</th><th>Item</th><th>Item Cat</th><th>Component</th><th>Description</th><th>Quantity</th><th>Unit</th><th>Usage</th><th>Plant</th><th>Sloc</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.BomComponents.OrderBy(c => c.Level).ThenBy(c => c.Item))
                                {
                                    <tr>
                                        <td>@item.Level</td><td>@item.Item</td><td>@item.ItemCat</td><td>@item.ComponentNumber</td><td>@item.Description</td><td>@item.ItemQuantity</td><td>@item.Unit</td><td>@item.BomUsage</td><td>@item.Plant</td><td>@item.Sloc</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- Routings Table -->
            @if (Model.Routings != null && Model.Routings.Any())
            {
                 <hr class="my-4">
                <div class="mb-4">
                    <h5 class="mb-3">Routings</h5>
                     <div class="table-responsive">
                        <table class="table table-sm table-bordered table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>Counter</th>
                                    <th>Plant</th>
                                    <th>Material</th>
                                    <th>Material Description</th>
                                    <th>Work Center</th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th>Base Qty</th>
                                    <th>Unit</th>
                                    <th>Direct Labor Cost</th>
                                    <th></th>
                                    <th></th>
                                    <th>Direct Expenses</th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th>Allocation Expense</th>
                                    <th></th>
                                    <th>Production Version</th>
                                    <th>Version</th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th></th>
                                    <th>Valid From</th>
                                    <th>Valid To</th>
                                    <th></th>
                                    <th>Maximum Lot Size</th>
                                    <th>Unit</th>
                                    <th>Alternative</th>
                                    <th>Bom Usage</th>
                                    <th></th>
                                    <th>Group</th>
                                    <th>Group Counter</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Routings)
                                {
                                    <tr>
                                       <td>@item.Counter</td>
                                       <td>@item.Plant</td>
                                       <td>@item.Material</td>
                                       <td>@item.Description</td>
                                       <td>@item.WorkCenter</td>
                                       <td></td>
                                       <td></td>
                                       <td></td>
                                       <td></td>
                                       <td></td>
                                       <td>@item.BaseQty</td>
                                       <td>@item.Unit</td>
                                       <td>@item.DirectLaborCosts</td>
                                       <td></td>
                                       <td></td>
                                       <td>@item.DirectExpenses</td>
                                       <td></td>
                                       <td></td>
                                       <td></td>
                                       <td></td>
                                       <td></td>
                                       <td>@item.AllocationExpense</td>
                                       <td></td>
                                       <td>@item.ProductionVersionCode</td>
                                       <td>@item.Version</td>
                                       <td></td>
                                       <td></td>
                                       <td></td>
                                       <td></td>
                                       <td></td>
                                       <td></td>
                                       <td>@item.ValidFrom?.ToString("yyyy-MM-dd")</td>
                                       <td>@item.ValidTo?.ToString("yyyy-MM-dd")</td>
                                       <td></td>
                                       <td>@item.MaximumLotSize</td>
                                       <td>@(string.IsNullOrWhiteSpace(item.Unit) ? item.BomUsage : item.Unit)</td>
                                       <td>@item.Alternative</td>
                                       <td>@(string.IsNullOrWhiteSpace(item.BomUsage) ? "1" : item.BomUsage)</td>
                                       <td></td>
                                       <td>@item.Group</td>
                                       <td>@item.GroupCounter</td>
                                       <td></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <!-- Action Buttons -->
            <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-5">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to List
                </a>
                <div class="btn-group" role="group">
                    <button type="button" class="btn btn-outline-success dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-file-export me-2"></i>Export
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li>
                            <a class="dropdown-item" asp-action="ExportExcel" asp-route-id="@Model.Id">
                                <i class="fas fa-file-excel me-2 text-success"></i>Export Excel
                            </a>
                        </li>
                    </ul>
                </div>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                    <i class="fas fa-pencil-alt me-2"></i>Edit Request
                </a> 
            </div>
        </div>
    </div>
</div>
<style>
    .description-box {
        background-color: #f8f9fa;
        border: 1px solid #e9ecef;
        border-radius: 8px;
        padding: 1rem;
        color: #495057;
    }
</style>

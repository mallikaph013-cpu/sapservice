@model myapp.Models.ViewModels.CreateRequestViewModel
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager

@{
    ViewData["Title"] = "Edit Service Request";
    var isRequesterEditor = ViewBag.IsRequesterEditor as bool? ?? false;
}

<style>
    body {
        background-color: #f4f7f6;
        color: #333;
    }

    .form-container {
        background: #ffffff;
        padding: 40px;
        border-radius: 12px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        margin-top: 50px;
        margin-bottom: 50px;
    }

    h1, h4 {
        font-weight: 700;
        color: #2c3e50;
        margin-bottom: 10px;
    }

    .subtitle {
        color: #7f8c8d;
        margin-bottom: 30px;
    }

    .control-label {
        font-weight: 600;
        margin-bottom: .5rem;
        color: #34495e;
    }

    .form-control,
    .form-select,
    .form-control:disabled,
    .form-control[readonly] {
        border-radius: 8px;
        border: 1px solid #dcdcdc;
        padding: 10px 15px;
        transition: all 0.3s ease;
        background-color: #fff;
    }
    
    .form-control:focus,
    .form-select:focus {
        border-color: #3498db;
        box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.2);
        outline: none;
    }

    input.form-control[readonly] {
         background-color: #ecf0f1;
        cursor: not-allowed;
    }

    select.form-control, select.form-select {
        cursor: pointer;
    }

    .btn-primary {
        background-color: #3498db;
        border-color: #3498db;
        padding: 12px 30px;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(52, 152, 219, 0.2);
    }

    .btn-primary:hover {
        background-color: #2980b9;
        border-color: #2980b9;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(52, 152, 219, 0.3);
    }

    .btn-save-orange {
        background-color: #f97316;
        border-color: #f97316;
        color: #fff;
        padding: 12px 30px;
        font-size: 1rem;
        font-weight: 600;
        border-radius: 8px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(249, 115, 22, 0.25);
    }

    .btn-save-orange:hover {
        background-color: #ea580c;
        border-color: #ea580c;
        color: #fff;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(234, 88, 12, 0.35);
    }
    
    .back-to-list {
        display: inline-block;
        margin-top: 20px;
        color: #3498db;
        text-decoration: none;
        font-weight: 500;
    }

    .back-to-list:hover {
        text-decoration: underline;
    }

    hr {
        margin-top: 2rem;
        margin-bottom: 2rem;
    }
</style>

<div class="form-container">
    <div class="text-center">
        <h1>Edit Service Request</h1>
        <p class="subtitle">Update the details of the request below.</p>
    </div>
    <hr />

    <form id="editForm" asp-action="Edit" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="FromImport" value="@Model.FromImport" />
        <input type="hidden" asp-for="Id" />
        <div>
            @if (ViewBag.ImportNotice != null)
            {
                <div class="alert alert-info">@ViewBag.ImportNotice</div>
            }
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        </div>

        <h4>Requester Information</h4>
        <p class="text-muted small">The requester's details are read-only.</p>
        <div class="row mb-4">
            <div class="col-md-4"><div class="form-group"><label asp-for="RequesterName" class="control-label"></label><input asp-for="RequesterName" class="form-control" readonly /></div></div>
            <div class="col-md-3"><div class="form-group"><label asp-for="Department" class="control-label"></label><input asp-for="Department" class="form-control" readonly /></div></div>
            <div class="col-md-2"><div class="form-group"><label asp-for="Section" class="control-label"></label><input asp-for="Section" class="form-control" readonly /></div></div>
            <div class="col-md-3"><div class="form-group"><label asp-for="RequesterPlant" class="control-label"></label><input asp-for="RequesterPlant" class="form-control" readonly /></div></div>
        </div>

        <hr />

        <h4>Request Details</h4>
        <div class="row g-3 mb-4">
             <div class="col-md-6"><div class="form-group"><label asp-for="RequestType" class="control-label"></label><select asp-for="RequestType" id="RequestType" class="form-select" asp-items="Html.GetEnumSelectList<myapp.Models.RequestType>()" disabled="@(!isRequesterEditor)"></select>@if (!isRequesterEditor) { <input type="hidden" asp-for="RequestType" /> }<span asp-validation-for="RequestType" class="text-danger"></span></div></div>
             <div class="col-md-6" id="request-plant-container"><div class="form-group"><label asp-for="Plant" class="control-label"></label><select asp-for="Plant" id="RequestPlant" class="form-select" disabled="@(!isRequesterEditor)"><option value="">-- Select Plant --</option><option value="6021">6021 (Device)</option><option value="6031">6031 (Assembly)</option><option value="6051">6051 (Injection)</option><option value="6081">6081 (IPO)</option><option value="6090">6090</option></select>@if (!isRequesterEditor) { <input type="hidden" asp-for="Plant" /> }<span asp-validation-for="Plant" class="text-danger"></span></div></div>
             <div class="col-md-12">
                 <div class="form-group">
                    <label asp-for="Description" class="control-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-12" id="request-upload-container" style="display:none;">
                <div class="form-group">
                    <label for="RequestAttachment" class="control-label">Upload File</label>
                    <input class="form-control" type="file" id="RequestAttachment" name="requestAttachment" />
                    @if (!string.IsNullOrWhiteSpace(ViewBag.CurrentAttachmentPath as string))
                    {
                        <div class="mt-2">
                            <a href="@ViewBag.CurrentAttachmentPath" target="_blank" rel="noopener">
                                Current file: @(string.IsNullOrWhiteSpace(ViewBag.CurrentAttachmentFileName as string) ? "Attached file" : ViewBag.CurrentAttachmentFileName)
                            </a>
                        </div>
                    }
                    <span class="text-danger field-validation-valid" data-valmsg-for="requestAttachment" data-valmsg-replace="true"></span>
                </div>
            </div>
        </div>

        <partial name="_MaterialForms" model="Model" />

        <div id="workflow-section">
            <hr />
            <h4>Approver</h4>
           @* <p class="text-muted small mb-3">Select a request type to see the list of available approvers.</p>*@
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="form-group">
                        <label for="NextResponsibleUserId" class="control-label">ผู้รับผิดชอบลำดับถัดไป</label>
                        <select asp-for="NextResponsibleUserId" id="NextResponsibleUserId" class="form-select">
                            @if (!string.IsNullOrWhiteSpace(Model.NextResponsibleUserId))
                            {
                                <option value="@Model.NextResponsibleUserId" selected="selected">@ViewBag.CurrentNextApproverName</option>
                            }
                            else
                            {
                                <option value="">-- Loading... --</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>
        
        @if (SignInManager.IsSignedIn(User) && User.IsInRole("IT"))
        {
            <hr />
            <h4>IT Status Update</h4>
             <div class="row mb-4">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Status" class="control-label"></label>
                        <select asp-for="Status" id="EditStatus" class="form-select">
                            <option value="Pending">Pending</option>
                            <option value="Run Standard Cost">Run Standard Cost</option>
                            <option value="Check and Confirm">Check and Confirm</option>
                            <option value="Release">Release</option>
                            <option value="Input Price">Input Price</option>
                            <option value="Complete">Complete</option>
                            <option value="Rejected">Rejected</option>
                        </select>
                    </div>
                </div>
            </div>
        }

        <div class="form-group text-center mt-5">

            @if (SignInManager.IsSignedIn(User) && User.IsInRole("IT"))
            {
                <button type="button" id="edit-reject-button" class="btn btn-danger me-2" onclick="rejectForm()">
                    <i class="fas fa-undo me-2"></i>ตีกลับ
                </button>
            }

           @*  <button type="button" class="btn btn-primary" onclick="saveForm()">
                <i class="fas fa-save me-2"></i>Save Changes
            </button> *@

            <button type="button" id="create-submit-button" class="btn btn-save-orange" onclick="saveForm()">
                <i class="fas fa-save me-2"></i>Save Changes
            </button>

        </div>


     
    </form>
    
    <div class="text-center">
        <a asp-action="Index" class="back-to-list">Back to List</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        const requestTypeSelect = document.getElementById('RequestType');
        const requestPlantSelect = document.getElementById('RequestPlant');
        const requesterNameInput = document.getElementById('RequesterName');
        const materialFieldsContainer = document.getElementById('material-fields-container');
        const allMaterialFields = materialFieldsContainer ? materialFieldsContainer.querySelectorAll('[data-types]') : [];
        const bomContainer = document.getElementById('bom-fields-container');
        const bomEditContainer = document.getElementById('bom-edit-fields-container');
        const routingContainer = document.getElementById('routing-fields-container');
        const licensePermissionContainer = document.getElementById('license-permission-fields-container');
        const editBomFgInput = document.getElementById('EditBomFg');
        const editBomAllFgCheckbox = document.getElementById('EditBomAllFg');
        const requestPlantContainer = document.getElementById('request-plant-container');
        const requestUploadContainer = document.getElementById('request-upload-container');
        const requestAttachmentInput = document.getElementById('RequestAttachment');
        const workflowSection = document.getElementById('workflow-section');
        const hasCurrentAttachment = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(!string.IsNullOrWhiteSpace(ViewBag.CurrentAttachmentPath as string)));
        const nextResponsibleUserSelect = document.getElementById('NextResponsibleUserId');
        const licenseRequestOptionSelect = document.getElementById('LicenseRequestOption');
        const licenseNewUsernameFields = document.getElementById('license-new-username-fields');
        const licenseAddPermissionFields = document.getElementById('license-add-permission-fields');
        const licensePrimaryUsernameInput = document.getElementById('LicensePrimaryUsername');
        const licenseSecondaryUsernameInput = document.getElementById('LicenseSecondaryUsername');
        const currentNextApproverId = '@(Model.NextResponsibleUserId ?? "")';
        const currentNextApproverName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((string)(ViewBag.CurrentNextApproverName ?? "Current Responsible User")));

        const typeMapping = {
            '0': 'Request',
            '1': 'FG',
            '2': 'SM',
            '3': 'RM',
            '4': 'ToolingB',
            '5': 'ToolingBFG',
            '6': 'ToolingBPU',
            '7': 'BOM',
            '8': 'Routing',
            '9': 'AddStorage',
            '10':'DistributionChanel',
            '11':'IPO',
            '12':'Passthrough',
            '13':'CrossPlantPurchase',
            '14':'EditBOM',
            '15':'LicensePermission'
        };

        function toggleMaterialFields() {
            const selectedValue = requestTypeSelect ? requestTypeSelect.value : null;
            // support enum value as numeric string or as name (e.g. "6" or "BOM")
            let selectedTypeName = null;
            if (selectedValue) {
                selectedTypeName = typeMapping[selectedValue] || selectedValue;
            }
            // Treat EditBOM (localized display) as BOM
            //if (selectedTypeName === 'EditBOM' || selectedTypeName === '�� BOM') {
            //    selectedTypeName = 'EditBOM';
            // }
            const isSimpleRequest = selectedTypeName === 'Request' || selectedTypeName === 'ร้องขอ';

            const showMaterialFields = selectedValue && !isSimpleRequest && selectedTypeName !== 'Routing' && selectedTypeName !== 'LicensePermission';
            if (materialFieldsContainer) {
                materialFieldsContainer.style.display = showMaterialFields ? 'block' : 'none';

                if (showMaterialFields && allMaterialFields.length) {
                     allMaterialFields.forEach(field => {
                        const parentCol = field.closest('.col-md-4, .col-md-6, .col-md-8, .col-md-12');
                        if (parentCol) {
                            const types = parentCol.dataset.types ? parentCol.dataset.types.split(',') : [];
                            if (selectedTypeName && types.includes(selectedTypeName)) {
                                parentCol.style.display = 'block';
                            } else {
                                parentCol.style.display = 'none';
                            }
                        }
                    });
                }
            }

            if (requestPlantContainer) {
                requestPlantContainer.style.display = isSimpleRequest ? 'none' : 'block';
            }

            if (requestPlantSelect) {
                requestPlantSelect.disabled = isSimpleRequest;
                if (isSimpleRequest) {
                    requestPlantSelect.value = '';
                }
            }

            if (workflowSection) {
                workflowSection.style.display = 'block';
            }

            if (requestUploadContainer) {
                requestUploadContainer.style.display = isSimpleRequest ? 'block' : 'none';
            }

            if (requestAttachmentInput) {
                requestAttachmentInput.disabled = !isSimpleRequest;
                requestAttachmentInput.required = isSimpleRequest && !hasCurrentAttachment;
                if (!isSimpleRequest) {
                    requestAttachmentInput.value = '';
                }
            }

            if (bomContainer) bomContainer.style.display = selectedTypeName === 'BOM' ? 'block' : 'none';
            if (bomEditContainer) bomEditContainer.style.display = selectedTypeName === 'EditBOM' ? 'block' : 'none';
            if (routingContainer) routingContainer.style.display = selectedTypeName === 'Routing' ? 'block' : 'none';
            if (licensePermissionContainer) licensePermissionContainer.style.display = selectedTypeName === 'LicensePermission' ? 'block' : 'none';
        }

        function toggleEditBomFgInput() {
            if (!editBomFgInput || !editBomAllFgCheckbox) return;
            const isAllFgChecked = editBomAllFgCheckbox.checked;
            editBomFgInput.disabled = isAllFgChecked;
            if (isAllFgChecked) {
                editBomFgInput.value = '';
            }
        }

        function setSectionEnabled(section, enabled) {
            if (!section) return;
            const controls = section.querySelectorAll('input, select, textarea, button');
            controls.forEach(control => {
                control.disabled = !enabled;
            });
        }

        function toggleLicenseRequestOptionFields() {
            const selectedOption = licenseRequestOptionSelect ? licenseRequestOptionSelect.value : '';
            const isNewUsernameRequest = selectedOption === 'NewUsername';
            const isAddPermissionRequest = selectedOption === 'AddPermission';

            if (licenseNewUsernameFields) {
                licenseNewUsernameFields.style.display = isNewUsernameRequest ? 'block' : 'none';
                setSectionEnabled(licenseNewUsernameFields, isNewUsernameRequest);
            }

            if (licenseAddPermissionFields) {
                licenseAddPermissionFields.style.display = isAddPermissionRequest ? 'block' : 'none';
                setSectionEnabled(licenseAddPermissionFields, isAddPermissionRequest);
            }
        }

        function fetchNextApprovers() {
            if (!requestTypeSelect || !nextResponsibleUserSelect) return;

            const requestTypeValue = requestTypeSelect.value;
            const selectedPlant = requestPlantSelect ? requestPlantSelect.value : '';
            const requesterNameValue = requesterNameInput ? requesterNameInput.value : '';
            nextResponsibleUserSelect.innerHTML = '<option value="">-- Loading... --</option>';

            const renderApproverOptions = (data) => {
                nextResponsibleUserSelect.innerHTML = '<option value="">-- Please select a responsible user --</option>';

                let matchedCurrentApprover = false;

                data.forEach(user => {
                    const stepPrefix = user.step ? `Step ${user.step} - ` : '';
                    const option = new Option(`${stepPrefix}${user.fullName}`, user.id);
                    if (currentNextApproverId && (user.id === currentNextApproverId || user.id.startsWith(currentNextApproverId + '|'))) {
                        option.selected = true;
                        matchedCurrentApprover = true;
                    }
                    nextResponsibleUserSelect.add(option);
                });

                if (currentNextApproverId && !matchedCurrentApprover) {
                    const fallbackOption = new Option(`${currentNextApproverName} (Current)`, currentNextApproverId);
                    fallbackOption.selected = true;
                    nextResponsibleUserSelect.add(fallbackOption);
                }
            };

            if (!requestTypeValue) {
                nextResponsibleUserSelect.innerHTML = '<option value="">-- Please select a request type first --</option>';
                return;
            }

            fetch(`/Requests/GetNextApprovers?requestType=${encodeURIComponent(requestTypeValue)}&plant=${encodeURIComponent(selectedPlant)}&requesterName=${encodeURIComponent(requesterNameValue)}&currentApproverId=${encodeURIComponent(currentNextApproverId || '')}`)
                .then(response => response.json())
                .then(data => {
                    if (!data || data.length === 0) {
                        // Fallback: retry without plant filter in case route config uses different plant labels.
                        return fetch(`/Requests/GetNextApprovers?requestType=${encodeURIComponent(requestTypeValue)}&requesterName=${encodeURIComponent(requesterNameValue)}&currentApproverId=${encodeURIComponent(currentNextApproverId || '')}`)
                            .then(r => r.json())
                            .then(fallbackData => {
                                if (fallbackData && fallbackData.length > 0) {
                                    renderApproverOptions(fallbackData);
                                } else if (currentNextApproverId) {
                                    nextResponsibleUserSelect.innerHTML = '';
                                    const fallbackOption = new Option(currentNextApproverName, currentNextApproverId);
                                    fallbackOption.selected = true;
                                    nextResponsibleUserSelect.add(fallbackOption);
                                } else {
                                    nextResponsibleUserSelect.innerHTML = '<option value="">-- No users found --</option>';
                                }
                            });
                    }

                    renderApproverOptions(data);
                })
                .catch(() => {
                    if (currentNextApproverId) {
                        nextResponsibleUserSelect.innerHTML = '';
                        const fallbackOption = new Option(currentNextApproverName, currentNextApproverId);
                        fallbackOption.selected = true;
                        nextResponsibleUserSelect.add(fallbackOption);
                    }
                    else {
                        nextResponsibleUserSelect.innerHTML = '<option value="">-- Error loading data --</option>';
                    }
                });
        }

        function addBomItem(level) {
            const tbody = document.getElementById('bom-items-body');
            const index = tbody.getElementsByTagName('tr').length;
            const newRow = `
                <tr>
                    <td><input type="text" name="Components[${index}].Level" class="form-control" value="${level}" readonly/></td>
                    <td><input type="text" name="Components[${index}].Item" class="form-control" /></td>
                    <td><input type="text" name="Components[${index}].ItemCat" class="form-control" /></td>
                    <td><input type="text" name="Components[${index}].ComponentNumber" class="form-control" /></td>
                    <td><input type="text" name="Components[${index}].Description" class="form-control" /></td>
                    <td><input type="number" name="Components[${index}].ItemQuantity" class="form-control" /></td>
                    <td><input type="text" name="Components[${index}].Unit" class="form-control" /></td>
                    <td><input type="text" name="Components[${index}].BomUsage" class="form-control" /></td>
                    <td><input type="text" name="Components[${index}].Plant" class="form-control" /></td>
                    <td><input type="text" name="Components[${index}].Sloc" class="form-control" /></td>
                    <td><button type="button" class="btn btn-danger btn-sm remove-bom-item">Remove</button></td>
                </tr>`;
            tbody.insertAdjacentHTML('beforeend', newRow);
        }
        
        document.getElementById('add-parent-item').addEventListener('click', () => addBomItem(1));
        document.getElementById('add-child-item').addEventListener('click', () => addBomItem(2));

        document.getElementById('bom-items-body').addEventListener('click', function(e) {
            if (e.target && e.target.classList.contains('remove-bom-item')) {
                e.target.closest('tr').remove();
            }
        });

        document.getElementById('add-routing-item').addEventListener('click', function() {
            const tbody = document.getElementById('routing-items-body');
            const index = tbody.rows.length;
            const row = `
                <tr>
                    <td><input class="form-control" type="text" name="Routings[${index}].Counter"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].Plant"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].Material"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].Description"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].WorkCenter"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td><input class="form-control" type="number" step="0.01" name="Routings[${index}].BaseQty" value="1"></td>
                    <td><input class="form-control routing-unit-source" type="text" name="Routings[${index}].Unit"></td>
                    <td><input class="form-control" type="number" step="0.01" name="Routings[${index}].DirectLaborCosts"></td>
                    <td><input class="form-control" type="number" step="0.01" name="Routings[${index}].DirectExpenses"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td class="routing-spacer-col"></td>
                    <td><input class="form-control" type="number" step="0.01" name="Routings[${index}].AllocationExpense"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].ProductionVersionCode"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].Version"></td>
                    <td class="routing-spacer-col"></td>
                    <td><input class="form-control" type="date" name="Routings[${index}].ValidFrom"></td>
                    <td><input class="form-control" type="date" name="Routings[${index}].ValidTo" value="9999-12-13"></td>
                    <td><input class="form-control" type="number" step="0.01" name="Routings[${index}].MaximumLotSize" value="99999999"></td>
                    <td><input class="form-control routing-unit-mirror" type="text" readonly></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].Alternative" value="1" readonly></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].BomUsage" value="1"></td>
                    <td class="routing-spacer-col"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].Group"></td>
                    <td><input class="form-control" type="text" name="Routings[${index}].GroupCounter" value="1"></td>
                   
                    <td><button type="button" class="btn btn-danger btn-sm remove-routing-item">Remove</button></td>
                </tr>`;
            tbody.insertAdjacentHTML('beforeend', row);
        });

        const routingItemsBody = document.getElementById('routing-items-body');
        if (routingItemsBody) {
            const syncRoutingUnitMirror = (row) => {
                const source = row.querySelector('.routing-unit-source');
                const mirror = row.querySelector('.routing-unit-mirror');
                if (source && mirror) {
                    mirror.value = source.value || '';
                }
            };

            routingItemsBody.querySelectorAll('tr').forEach(syncRoutingUnitMirror);

            routingItemsBody.addEventListener('input', function(e) {
                if (e.target && e.target.classList.contains('routing-unit-source')) {
                    const row = e.target.closest('tr');
                    if (row) {
                        syncRoutingUnitMirror(row);
                    }
                }
            });

            routingItemsBody.addEventListener('click', function(e) {
                if (e.target && e.target.classList.contains('remove-routing-item')) {
                    e.target.closest('tr').remove();
                }
            });
        }

        const addLicensePermissionBtn = document.getElementById('add-license-permission-item');

        function getLicenseUsernames() {
            const usernames = [];
            const primary = licensePrimaryUsernameInput ? licensePrimaryUsernameInput.value.trim() : '';
            const secondary = licenseSecondaryUsernameInput ? licenseSecondaryUsernameInput.value.trim() : '';
            if (primary) usernames.push(primary);
            if (secondary) usernames.push(secondary);
            return usernames;
        }

        function getCombinedLicenseUsernames() {
            return getLicenseUsernames().join(' / ');
        }

        function syncLicensePermissionUsernames() {
            const combinedUsernames = getCombinedLicenseUsernames();
            const usernameInputs = document.querySelectorAll('#license-permission-items-body .license-permission-username');
            usernameInputs.forEach(input => {
                input.value = combinedUsernames;
            });
        }

        function hydrateLicenseUsernameInputsFromRows() {
            if (!licensePrimaryUsernameInput || !licenseSecondaryUsernameInput) return;
            const usernameInputs = document.querySelectorAll('#license-permission-items-body .license-permission-username');
            const rawValues = Array.from(usernameInputs)
                .map(input => (input.value || '').trim())
                .filter(value => value.length > 0);

            if (!rawValues.length) return;

            const parsedUsers = [];
            rawValues.forEach(value => {
                value.split(/\s*\/\s*|\s*,\s*/)
                    .map(part => part.trim())
                    .filter(part => part.length > 0)
                    .forEach(user => {
                        if (!parsedUsers.includes(user)) {
                            parsedUsers.push(user);
                        }
                    });
            });

            if (parsedUsers[0]) licensePrimaryUsernameInput.value = parsedUsers[0];
            if (parsedUsers[1]) licenseSecondaryUsernameInput.value = parsedUsers[1];
            syncLicensePermissionUsernames();
        }

        if (addLicensePermissionBtn) {
            addLicensePermissionBtn.addEventListener('click', function () {
                const tbody = document.getElementById('license-permission-items-body');
                if (!tbody) return;
                const index = tbody.getElementsByTagName('tr').length;
                const combinedUsernames = getCombinedLicenseUsernames();
                const row = `
                    <tr>
                        <td>
                            <input class="license-permission-username" type="hidden" name="LicensePermissions[${index}].SapUsername" value="${combinedUsernames}">
                            <input class="form-control" type="text" name="LicensePermissions[${index}].TCode">
                        </td>
                        <td><button type="button" class="btn btn-danger btn-sm remove-license-permission-item">Remove</button></td>
                    </tr>`;
                tbody.insertAdjacentHTML('beforeend', row);
            });
        }

        const licensePermissionBody = document.getElementById('license-permission-items-body');
        if (licensePermissionBody) {
            licensePermissionBody.addEventListener('click', function (e) {
                if (e.target && e.target.classList.contains('remove-license-permission-item')) {
                    e.target.closest('tr').remove();
                }
            });
        }

        // Initial call to set the correct fields on page load
        toggleMaterialFields();
        toggleEditBomFgInput();
        fetchNextApprovers();
        hydrateLicenseUsernameInputsFromRows();
        toggleLicenseRequestOptionFields();
        requestTypeSelect.addEventListener('change', function() {
            toggleMaterialFields();
            fetchNextApprovers();
        });

        if (requestPlantSelect) {
            requestPlantSelect.addEventListener('change', fetchNextApprovers);
        }

        // Sync header Plant dropdown → Material section Plant display field
        const materialSectionPlant = document.getElementById('MaterialSectionPlant');
        if (requestPlantSelect && materialSectionPlant) {
            const syncMaterialPlant = () => { materialSectionPlant.value = requestPlantSelect.value; };
            requestPlantSelect.addEventListener('change', syncMaterialPlant);
            syncMaterialPlant();
        }

        if (licenseRequestOptionSelect) {
            licenseRequestOptionSelect.addEventListener('change', toggleLicenseRequestOptionFields);
        }
        if (licensePrimaryUsernameInput) {
            licensePrimaryUsernameInput.addEventListener('input', syncLicensePermissionUsernames);
        }
        if (licenseSecondaryUsernameInput) {
            licenseSecondaryUsernameInput.addEventListener('input', syncLicensePermissionUsernames);
        }
        if (editBomAllFgCheckbox) {
            editBomAllFgCheckbox.addEventListener('change', toggleEditBomFgInput);
        }

        // Expose a global saveForm function to validate then submit the form
        window.saveForm = function () {
            const form = document.getElementById('editForm');
            if (!form) return;
            const statusSelect = document.getElementById('EditStatus');
            const descriptionInput = document.getElementById('Description');
            const isRejected = statusSelect && statusSelect.value === 'Rejected';
            const hasRemark = descriptionInput && descriptionInput.value && descriptionInput.value.trim().length > 0;

            if (isRejected && !hasRemark) {
                alert('กรุณากรอกหมายเหตุก่อนตีกลับ (Reject)');
                if (descriptionInput) {
                    descriptionInput.focus();
                }
                return;
            }

            // If this edit was opened from import, bypass client-side HTML5 validation
            const fromImportInput = form.querySelector('input[name="FromImport"]');
            const fromImport = fromImportInput && (fromImportInput.value === 'True' || fromImportInput.value === 'true');
            if (fromImport) {
                // submit without HTML5 validation so server-side relaxed validation can run
                syncLicensePermissionUsernames();
                form.submit();
                return;
            }

            // Use HTML5 validation: reportValidity shows messages in supported browsers
            if (form.checkValidity()) {
                syncLicensePermissionUsernames();
                form.submit();
            } else if (typeof form.reportValidity === 'function') {
                form.reportValidity();
            }
        };

        window.rejectForm = function () {
            const statusSelect = document.getElementById('EditStatus');
            if (statusSelect) {
                statusSelect.value = 'Rejected';
            }
            window.saveForm();
        };
    });
    </script>
}

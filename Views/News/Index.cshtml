@model IEnumerable<myapp.Models.NewsArticle>

@{
    ViewData["Title"] = "News Management";
}

<style>
    body {
        background:
            radial-gradient(circle at top left, rgba(249, 115, 22, 0.16), transparent 26%),
            radial-gradient(circle at top right, rgba(251, 191, 36, 0.14), transparent 20%),
            linear-gradient(180deg, #fff7ed 0%, #fffaf5 46%, #ffffff 100%);
    }

    .news-admin-shell {
        max-width: 1120px;
        margin: 2.5rem auto 3rem;
        padding: 0 1rem;
    }

    .news-admin-hero {
        position: relative;
        overflow: hidden;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        background: linear-gradient(135deg, #ea580c 0%, #fb923c 58%, #ffedd5 170%);
        color: #fff7ed;
        border-radius: 30px;
        padding: 2.25rem;
        box-shadow: 0 28px 65px rgba(234, 88, 12, 0.2);
        margin-bottom: 1.5rem;
    }

    .news-admin-hero::after {
        content: "";
        position: absolute;
        right: -70px;
        top: -100px;
        width: 260px;
        height: 260px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.08);
    }

    .news-admin-title {
        font-size: clamp(2.1rem, 4vw, 3.2rem);
        font-weight: 800;
        margin: 0 0 0.55rem;
        color: #fff;
    }

    .news-admin-copy {
        margin: 0;
        max-width: 620px;
        color: rgba(255, 247, 237, 0.92);
        line-height: 1.7;
    }

    .news-admin-create {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-height: 44px;
        padding: 0.8rem 1.2rem;
        border-radius: 999px;
        background: #fff;
        color: #c2410c;
        text-decoration: none;
        font-weight: 800;
        box-shadow: 0 10px 24px rgba(194, 65, 12, 0.12);
        z-index: 1;
    }

    .news-admin-create:hover {
        color: #9a3412;
        text-decoration: none;
    }

    .news-success {
        border: none;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.9);
        color: #9a3412;
        box-shadow: 0 18px 42px rgba(194, 65, 12, 0.08);
    }

    .news-table-card {
        background: rgba(255, 255, 255, 0.92);
        border: 1px solid rgba(251, 146, 60, 0.16);
        border-radius: 28px;
        padding: 1rem;
        box-shadow: 0 20px 48px rgba(194, 65, 12, 0.08);
        backdrop-filter: blur(10px);
    }

    .news-table {
        margin-bottom: 0;
    }

    .news-table thead th {
        border-bottom: none;
        background: rgba(255, 237, 213, 0.7);
        color: #9a3412;
        font-weight: 800;
        padding: 1rem;
    }

    .news-table thead th:first-child {
        border-top-left-radius: 18px;
        border-bottom-left-radius: 18px;
    }

    .news-table thead th:last-child {
        border-top-right-radius: 18px;
        border-bottom-right-radius: 18px;
    }

    .news-table tbody td {
        padding: 1rem;
        vertical-align: middle;
        border-color: rgba(249, 115, 22, 0.08);
        color: #6b4f3a;
    }

    .news-table tbody tr:hover {
        background: rgba(255, 247, 237, 0.82);
    }

    .news-title-cell {
        font-weight: 700;
        color: #9a3412;
    }

    .news-featured-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.42rem 0.72rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 800;
    }

    .news-featured-yes {
        background: rgba(249, 115, 22, 0.14);
        color: #c2410c;
    }

    .news-featured-no {
        background: rgba(255, 237, 213, 0.9);
        color: #9a6b47;
    }

    .news-actions {
        display: inline-flex;
        align-items: center;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 0.55rem;
    }

    .news-action-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        min-height: 36px;
        padding: 0.55rem 0.85rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .news-action-edit {
        background: rgba(255, 237, 213, 0.9);
        color: #c2410c;
    }

    .news-action-delete {
        background: rgba(254, 226, 226, 0.9);
        color: #b91c1c;
    }

    .news-empty {
        padding: 3rem 1.5rem;
        text-align: center;
        color: #9a6b47;
    }

    @@media (max-width: 767.98px) {
        .news-admin-hero {
            padding: 1.8rem 1.4rem;
            border-radius: 24px;
        }

        .news-table-card {
            padding: 0.8rem;
            border-radius: 22px;
        }

        .news-table thead {
            display: none;
        }

        .news-table,
        .news-table tbody,
        .news-table tr,
        .news-table td {
            display: block;
            width: 100%;
        }

        .news-table tr {
            padding: 1rem;
            border-bottom: 1px solid rgba(249, 115, 22, 0.08);
        }

        .news-table tr:last-child {
            border-bottom: none;
        }

        .news-table tbody td {
            padding: 0.45rem 0;
            border: none;
        }

        .news-actions {
            justify-content: flex-start;
        }
    }
</style>

<div class="news-admin-shell">
    <section class="news-admin-hero">
        <div>
            <h1 class="news-admin-title"><i class="fas fa-newspaper me-2"></i>@ViewData["Title"]</h1>
            <p class="news-admin-copy">จัดการข่าวทั้งหมดในธีมเดียวกับหน้าแสดงผลข่าว เพิ่ม แก้ไข และลบรายการได้จากตารางที่อ่านง่ายและโทนสีส้ม-ขาวต่อเนื่องกันทั้งระบบ</p>
        </div>
        <a asp-action="Create" class="news-admin-create">
            <i class="fas fa-plus"></i>Create New
        </a>
    </section>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show news-success" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="news-table-card">
        <div>
            @if (Model.Any())
            {
            <table class="table news-table align-middle">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Author</th>
                        <th>Published Date</th>
                        <th>Featured</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model)
            {
                    <tr>
                        <td class="news-title-cell">
                           @Html.DisplayFor(modelItem => item.Title)
                        </td>
                        <td>
                           @Html.DisplayFor(modelItem => item.Author)
                        </td>
                        <td>
                            @item.PublishedDate.ToString("d MMMM yyyy")
                        </td>
                        <td>
                            <span class="news-featured-badge @(item.IsFeatured ? "news-featured-yes" : "news-featured-no")">
                                <i class="fas @(item.IsFeatured ? "fa-star" : "fa-circle")"></i>@(item.IsFeatured ? "Yes" : "No")
                            </span>
                        </td>
                        <td class="text-end">
                            <span class="news-actions">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="news-action-btn news-action-edit">
                                    <i class="fas fa-edit"></i>Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="news-action-btn news-action-delete">
                                    <i class="fas fa-trash"></i>Delete
                                </a>
                            </span>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
            }
            else
            {
                <div class="news-empty">
                    <i class="fas fa-newspaper fa-2x mb-3"></i>
                    <p class="mb-0">No news articles found.</p>
                </div>
            }
        </div>
    </div>
</div>


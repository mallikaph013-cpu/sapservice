@model myapp.Models.ViewModels.DocumentRoutingViewModel

@{ 
    ViewData["Title"] = "Document Routing";
}

@*<h1 class="mb-4">Document Routing Management</h1>*@

<div class="card mb-4">
    <div class="card-header">
        <h2 class="card-title mb-0">Create New Document Routing</h2>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <div class="form-group">
                        <label asp-for="CreateForm.NewDocumentTypeName" class="control-label">Document Type</label>
                        <select asp-for="CreateForm.NewDocumentTypeName" asp-items="Model.DocumentTypeList" class="form-control">
                            <option value="">-- Select Document Type --</option>
                        </select>
                        <span asp-validation-for="CreateForm.NewDocumentTypeName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label asp-for="CreateForm.DepartmentId" class="control-label">Department</label>
                        <select asp-for="CreateForm.DepartmentId" asp-items="Model.DepartmentList" class="form-control">
                             <option value="">-- Select Department --</option>
                        </select>
                        <span asp-validation-for="CreateForm.DepartmentId" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label asp-for="CreateForm.NewSectionName" class="control-label">Section</label>
                        <select asp-for="CreateForm.NewSectionName" asp-items="Model.SectionList" class="form-control">
                             <option value="">-- Select Section --</option>
                        </select>
                        <span asp-validation-for="CreateForm.NewSectionName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <label asp-for="CreateForm.NewPlantName" class="control-label">Plant</label>
                        <select asp-for="CreateForm.NewPlantName" asp-items="Model.PlantList" class="form-control">
                             <option value="">-- Select Plant --</option>
                        </select>
                        <span asp-validation-for="CreateForm.NewPlantName" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-1">
                    <div class="form-group">
                        <label asp-for="CreateForm.Step" class="control-label"></label>
                        <input asp-for="CreateForm.Step" class="form-control" />
                        <span asp-validation-for="CreateForm.Step" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="form-group">
                        <button type="submit" class="btn btn-primary w-100"><i class="fas fa-plus me-1"></i> Create</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@if (TempData["ImportReport"] != null)
{
    <div class="alert alert-warning">
        <strong>Import row report</strong>
        <pre class="mb-0 mt-2" style="white-space: pre-wrap;">@TempData["ImportReport"]</pre>
    </div>
}

<div class="card mb-4">
    <div class="card-header">
        <h2 class="card-title mb-0">Import Document Routing</h2>
    </div>
    <div class="card-body">
        <form asp-action="Import" method="post" enctype="multipart/form-data">
            <div class="row g-3 align-items-end">
                <div class="col-md-9">
                    <label for="documentRoutingImportFile" class="form-label">CSV/XLSX File</label>
                    <input type="file" id="documentRoutingImportFile" name="importFile" class="form-control" accept=".csv,.xlsx" required />
                    <small class="text-muted">Columns: DocumentType,DepartmentName,SectionName,PlantName,Step</small>
                </div>
                <div class="col-md-3">
                    <div class="d-grid gap-2">
                        <a asp-action="DownloadImportTemplate" class="btn btn-outline-secondary"><i class="fas fa-download me-1"></i> Download Template</a>
                        <button type="submit" class="btn btn-success"><i class="fas fa-upload me-1"></i> Import</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

<div class="card">
    <div class="card-header">
        <h2 class="card-title mb-0">Document Routing Sequences</h2>
    </div>
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <thead>
                <tr>
                    <th>Document Type</th>
                    <th>Department</th>
                    <th>Section</th>
                    <th>Plant</th>
                    <th>Step</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DocumentRoutings)
                {
                    <tr>
                        <td>@item.DocumentType.Name</td>
                        <td>@item.Department.DepartmentName</td>
                        <td>@item.Section.SectionName</td>
                        <td>@item.Plant.PlantName</td>
                        <td>@item.Step</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-icon btn-warning me-2" data-bs-toggle="tooltip" title="Edit">
                                <i class="fas fa-pencil-alt"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-icon btn-danger" data-bs-toggle="tooltip" title="Delete">
                                <i class="fas fa-trash-alt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        // Initialize Bootstrap tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })

        document.addEventListener('DOMContentLoaded', function () {
            const departmentSelect = document.getElementById('CreateForm_DepartmentId');
            const sectionSelect = document.getElementById('CreateForm_NewSectionName');
            const plantSelect = document.getElementById('CreateForm_NewPlantName');
            const sectionUrl = '@Url.Action("GetSectionsByDepartment", "DocumentRouting")';
            const plantUrl = '@Url.Action("GetPlantsByDepartment", "DocumentRouting")';

            if (!departmentSelect || !sectionSelect || !plantSelect) {
                return;
            }

            const selectedSectionOnLoad = sectionSelect.value;
            const selectedPlantOnLoad = plantSelect.value;

            const loadSections = async (departmentId, selectedSection = '') => {
                sectionSelect.innerHTML = '<option value="">-- Select Section --</option>';

                if (!departmentId) {
                    return;
                }

                try {
                    const response = await fetch(`${sectionUrl}?departmentId=${encodeURIComponent(departmentId)}`);
                    if (!response.ok) {
                        return;
                    }

                    const sections = await response.json();
                    sections.forEach((section) => {
                        const option = document.createElement('option');
                        option.value = section.name;
                        option.textContent = section.name;
                        if (selectedSection && selectedSection === section.name) {
                            option.selected = true;
                        }
                        sectionSelect.appendChild(option);
                    });
                } catch (error) {
                    console.error('Failed to load sections by department', error);
                }
            };

            const loadPlants = async (departmentId, selectedPlant = '') => {
                plantSelect.innerHTML = '<option value="">-- Select Plant --</option>';

                try {
                    const query = departmentId ? `?departmentId=${encodeURIComponent(departmentId)}` : '';
                    const response = await fetch(`${plantUrl}${query}`);
                    if (!response.ok) {
                        return;
                    }

                    const plants = await response.json();
                    plants.forEach((plant) => {
                        const option = document.createElement('option');
                        option.value = plant.name;
                        option.textContent = plant.name;
                        if (selectedPlant && selectedPlant === plant.name) {
                            option.selected = true;
                        }
                        plantSelect.appendChild(option);
                    });
                } catch (error) {
                    console.error('Failed to load plants by department', error);
                }
            };

            departmentSelect.addEventListener('change', function () {
                loadSections(this.value);
                loadPlants(this.value);
            });

            if (departmentSelect.value) {
                loadSections(departmentSelect.value, selectedSectionOnLoad);
                loadPlants(departmentSelect.value, selectedPlantOnLoad);
            } else {
                sectionSelect.innerHTML = '<option value="">-- Select Section --</option>';
                loadPlants('', selectedPlantOnLoad);
            }
        });
    </script>
}
